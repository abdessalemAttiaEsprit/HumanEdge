# Copy this file to .env (gitignored) and fill in real values.
# Used by docker-compose.yml for the backend's SMTP config (OTP emails).

# Gmail address used to send OTP emails.
MAIL_USERNAME=your-address@gmail.com

# Gmail App Password (NOT your regular Gmail password).
# Gmail requires an App Password for SMTP auth since 2022.
# Generate one at: Google Account -> Security -> 2-Step Verification -> App passwords
# (2-Step Verification must be enabled first)
MAIL_PASSWORD=xxxx xxxx xxxx xxxx
